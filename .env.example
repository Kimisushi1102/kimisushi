# KIMI SUSHI POS - ENVIRONMENT CONFIGURATION
# Copy file nay thanh file .env va dien thong tin cua ban

PORT=3000

# --- TELEGRAM SETTINGS ---
# Lay tu @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Lay tu @userinfobot hoac @GetMyChatID_Bot
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# --- GMAIL SMTP SETTINGS (Nhận thông báo đơn hàng) ---
# Bật/tắt tính năng gửi email qua Gmail
GMAIL_ENABLED=true

# Email Gmail của bạn (dùng để gửi thông báo)
GMAIL_USER=your-email@gmail.com

# App Password từ Google (16 ký tự, không phải mật khẩu thường)
# Tạo tại: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email nhận thông báo (mặc định = GMAIL_USER)
GMAIL_NOTIFY_EMAIL=notify@example.com

# --- DOMAIN SETTINGS ---
# Dia chi website cua bạn (Dung de tao link xac nhan don hang)
# Vi du: https://kimi-sushi.de hoac http://123.456.78.90:3000
VPS_DOMAIN=http://localhost:3000
