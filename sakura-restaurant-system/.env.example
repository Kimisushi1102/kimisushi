# ==========================================
# SAKURA RESTAURANT SYSTEM
# Environment Configuration Template
# ==========================================
# Copy this file to .env and fill in your values

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001/api

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sakura_restaurant
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ==========================================
# TELEGRAM BOT CONFIGURATION
# ==========================================
# Get your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your Telegram Chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here
# Set to true to enable webhook mode (recommended for production)
TELEGRAM_WEBHOOK_MODE=false
# Webhook URL (only needed if TELEGRAM_WEBHOOK_MODE is true)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# ==========================================
# EMAIL CONFIGURATION (SMTP)
# ==========================================
# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="Sakura Restaurant <noreply@sakura-restaurant.de>"

# ==========================================
# RESTAURANT SETTINGS
# ==========================================
RESTAURANT_NAME=Sakura Restaurant
RESTAURANT_ADDRESS=Bernhauser Hauptstrasse 27, 70794 Filderstadt
RESTAURANT_PHONE=+49 123 4567890
RESTAURANT_EMAIL=hallo@sakura-restaurant.de

# Opening Hours (HH:MM format)
OPENING_HOURS_MON=11:00-15:00,17:00-22:00
OPENING_HOURS_TUE=11:00-15:00,17:00-22:00
OPENING_HOURS_WED=11:00-15:00,17:00-22:00
OPENING_HOURS_THU=11:00-15:00,17:00-22:00
OPENING_HOURS_FRI=11:00-15:00,17:00-22:00
OPENING_HOURS_SAT=11:00-15:00,17:00-22:00
OPENING_HOURS_SUN=17:00-22:00

# ==========================================
# SECURITY
# ==========================================
# Generate a strong random string for JWT signing
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin password hash (bcrypt)
ADMIN_PASSWORD_HASH=your-hashed-admin-password

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=info
