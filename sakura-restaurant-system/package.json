{
  "name": "sakura-restaurant-system",
  "version": "1.0.0",
  "description": "Restaurant Ordering and Reservation System with Telegram Bot",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=backend",
    "setup": "npm install && npm run setup:db",
    "setup:db": "npm run db:migrate --workspace=backend && npm run db:seed --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
