{
  "version": 2,
  "buildCommand": null,
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/menu", "dest": "/api/menu.js" },
    { "src": "/api/combos", "dest": "/api/combos.js" },
    { "src": "/api/tables", "dest": "/api/tables.js" },
    { "src": "/api/inbox", "dest": "/api/inbox.js" },
    { "src": "/api/faq/all", "dest": "/api/faq-all.js" },
    { "src": "/api/faq", "dest": "/api/faq.js" },
    { "src": "/api/settings", "dest": "/api/settings.js" },
    { "src": "/api/transactions", "dest": "/api/transactions.js" },
    { "src": "/api/history", "dest": "/api/history.js" },
    { "src": "/api/reservations", "dest": "/api/reservations.js" },
    { "src": "/api/admin/login", "dest": "/api/admin/login.js" },
    { "src": "/api/admin/verify", "dest": "/api/admin/verify.js" },
    { "src": "/api/admin/change-password", "dest": "/api/admin/change-password.js" },
    { "src": "/api/admin/settings/seo", "dest": "/api/admin/settings/seo.js" },
    { "src": "/api/admin/settings/geo", "dest": "/api/admin/settings/geo.js" },
    { "src": "/api/admin/settings/hours", "dest": "/api/admin/settings/hours.js" },
    { "src": "/api/admin/activity-log", "dest": "/api/admin/activity-log.js" },
    { "src": "/api/analytics", "dest": "/api/analytics.js" },
    { "src": "/api/analytics/track", "dest": "/api/analytics/track.js" },
    { "src": "/api/analytics/reset", "dest": "/api/analytics/reset.js" },
    { "src": "/api/gmail-notify", "dest": "/api/gmail-notify.js" },
    { "src": "/api/gmail-test", "dest": "/api/gmail-test.js" },
    { "src": "/api/gmail-test-send", "dest": "/api/gmail-test-send.js" },
    { "src": "/api/test-telegram", "dest": "/api/test-telegram.js" },
    { "src": "/api/notify-admin", "dest": "/api/notify-admin.js" },
    { "src": "/api/notify-order", "dest": "/api/notify-order.js" },
    { "src": "/api/send-reply", "dest": "/api/send-reply.js" },
    { "src": "/sitemap.xml", "dest": "/api/sitemap.js" },
    { "src": "/robots.txt", "dest": "/api/robots.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "MONGODB_URL": "@MONGODB_URL",
    "GMAIL_ENABLED": "@GMAIL_ENABLED",
    "GMAIL_USER": "@GMAIL_USER",
    "GMAIL_APP_PASSWORD": "@GMAIL_APP_PASSWORD",
    "GMAIL_NOTIFY_EMAIL": "@GMAIL_NOTIFY_EMAIL",
    "TELEGRAM_BOT_TOKEN": "@TELEGRAM_BOT_TOKEN",
    "TELEGRAM_CHAT_ID": "@TELEGRAM_CHAT_ID"
  }
}
